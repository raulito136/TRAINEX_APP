<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:id="@+id/main">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerAjustes"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="@color/backgroundHeader"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Botón de retroceso como TextView -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/atras"
            android:textColor="@color/link"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Título centrado -->
        <TextView
            android:id="@+id/tvTituloAjustes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="@color/text"
            android:text="@string/ajustes" />

        <!-- Espacio para equilibrar -->
        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp" />

    </LinearLayout>

    <!-- Línea separadora inferior del header -->
    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/separator"
        app:layout_constraintTop_toBottomOf="@id/headerAjustes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ScrollView para todo el contenido -->
    <ScrollView
        android:id="@+id/scrollViewAjustes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/btnCerrarSesion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECCIÓN 1: CUENTA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cuenta"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:textColor="@color/text" />

            <!-- Perfil -->
            <LinearLayout
                android:id="@+id/lytPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ivPerfil"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_perfil_blanco"
                    app:tint="@color/secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/perfil"
                    android:textSize="16sp"
                    android:textColor="@color/text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flecha_abajo_blanca"
                    app:tint="@color/secondary"/>

            </LinearLayout>

            <!-- Cuenta -->
            <LinearLayout
                android:id="@+id/lytCuenta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ivCuenta"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_sobre_blanco"
                    app:tint="@color/secondary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cuenta_item"
                    android:textSize="16sp"
                    android:textColor="@color/text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flecha_abajo_blanca"
                    app:tint="@color/secondary"/>

            </LinearLayout>

            <!-- Notificaciones -->
            <LinearLayout
                android:id="@+id/lytNotificaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivNotificaciones"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_campana_blanca"
                    app:tint="@color/secondary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/notificaciones"
                    android:textSize="16sp"
                    android:textColor="@color/text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flecha_abajo_blanca"
                    app:tint="@color/secondary"/>

            </LinearLayout>

            <!-- SECCIÓN 2: PREFERENCIAS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/preferencias"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:textColor="@color/text" />

            <!-- Unidades -->
            <LinearLayout
                android:id="@+id/lytUnidades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ivUnidades"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_medida_blanca"
                    app:tint="@color/secondary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/unidades"
                    android:textSize="16sp"
                    android:textColor="@color/text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flecha_abajo_blanca"
                    app:tint="@color/secondary" />

            </LinearLayout>

            <!-- Idioma -->
            <LinearLayout
                android:id="@+id/lytIdioma"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ivIdioma"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_idioma_blanco"
                    app:tint="@color/secondary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/idioma"
                    android:textSize="16sp"
                    android:textColor="@color/text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flecha_abajo_blanca"
                    app:tint="@color/secondary"/>

            </LinearLayout>

            <!-- Modo -->
            <LinearLayout
                android:id="@+id/lytModo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivModo"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_luna_blanca"
                    app:tint="@color/secondary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/modo"
                    android:textSize="16sp"
                    android:textColor="@color/text" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flecha_abajo_blanca"
                    app:tint="@color/secondary"/>

            </LinearLayout>

            <!-- SECCIÓN 3: SÍGUENOS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/siguenos"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:textColor="@color/text" />

            <!-- CardView para redes sociales -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/backgroundCardView"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Redes sociales en horizontal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Instagram -->
                        <ImageView
                            android:id="@+id/ivInstagram"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:src="@drawable/ic_instagram"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground" />

                        <!-- Facebook -->
                        <ImageView
                            android:id="@+id/ivFacebook"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:src="@drawable/ic_facebook"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground" />

                        <!-- Twitter/X -->
                        <ImageView
                            android:id="@+id/ivTwitter"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:src="@drawable/ic_twitter_blanco"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            app:tint="@color/secondary"/>

                        <!-- YouTube -->
                        <ImageView
                            android:id="@+id/ivYoutube"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:src="@drawable/ic_youtube"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Botón de cerrar sesión -->
    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"

        android:background="@drawable/bg_btn_cerrar_sesion"
        android:text="@string/cerrar_sesion"
        android:textColor="@color/tercerColorFondoRojoBoton"
        android:textSize="16sp"
        android:textStyle="bold"

        android:backgroundTint="@null"
        app:backgroundTint="@null"

        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
