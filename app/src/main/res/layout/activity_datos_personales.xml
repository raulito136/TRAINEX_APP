<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:id="@+id/main">

    <!-- Header (igual que en ajustes) -->
    <LinearLayout
        android:id="@+id/headerDatosPersonales"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="@color/backgroundHeader"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Botón de retroceso como TextView -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/atras"
            android:textColor="@color/link"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Título centrado -->
        <TextView
            android:id="@+id/tvTituloDatosPersonales"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="@color/text"
            android:text="@string/titulo_ajustes_datos_personales" />

        <!-- Espacio para equilibrar -->
        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp" />

    </LinearLayout>

    <!-- Línea separadora inferior del header -->
    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/separator"
        app:layout_constraintTop_toBottomOf="@id/headerDatosPersonales"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ScrollView para contenido -->
    <ScrollView
        android:id="@+id/scrollViewDatosPersonales"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/btnGuardar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre -->
            <TextView
                android:id="@+id/tvLabelNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_nombre_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:hint="@string/hint_nombre_ajustes_datos_personales"
                android:inputType="textPersonName|textCapWords"
                android:padding="16dp"
                android:textColor="@color/text"
                android:textColorHint="@android:color/darker_gray" />

            <!-- Apellidos -->
            <TextView
                android:id="@+id/tvLabelApellidos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_apellidos_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etApellidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:hint="@string/hint_apellidos_ajustes_datos_personales"
                android:inputType="textPersonName|textCapWords"
                android:padding="16dp"
                android:textColor="@color/text"
                android:textColorHint="@android:color/darker_gray" />

            <!-- Género -->
            <TextView
                android:id="@+id/tvLabelGenero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_genero_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGenero"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvGenero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_genero_ajustes_datos_personales"
                    android:inputType="none"
                    android:textColor="@color/text"
                    android:textColorHint="@android:color/darker_gray" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Edad -->
            <TextView
                android:id="@+id/tvLabelEdad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_edad_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etEdad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:hint="@string/hint_edad_ajustes_datos_personales"
                android:inputType="number"
                android:padding="16dp"
                android:textColor="@color/text"
                android:textColorHint="@android:color/darker_gray" />

            <!-- Peso -->
            <TextView
                android:id="@+id/tvLabelPeso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_peso_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:hint="@string/hint_peso_ajustes_datos_personales"
                android:inputType="numberDecimal"
                android:padding="16dp"
                android:textColor="@color/text"
                android:textColorHint="@android:color/darker_gray" />

            <!-- Altura -->
            <TextView
                android:id="@+id/tvLabelAltura"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_altura_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etAltura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_ajustes_item"
                android:hint="@string/hint_altura_ajustes_datos_personales"
                android:inputType="numberDecimal"
                android:padding="16dp"
                android:textColor="@color/text"
                android:textColorHint="@android:color/darker_gray" />

            <!-- Estilo de vida -->
            <TextView
                android:id="@+id/tvLabelEstiloVida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_estilo_vida_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEstiloVida"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvEstiloVida"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_estilo_vida_ajustes_datos_personales"
                    android:inputType="none"
                    android:textColor="@color/text"
                    android:textColorHint="@android:color/darker_gray" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Objetivo -->
            <TextView
                android:id="@+id/tvLabelObjetivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_objetivo_ajustes_datos_personales"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilObjetivo"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvObjetivo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_objetivo_ajustes_datos_personales"
                    android:inputType="none"
                    android:textColor="@color/text"
                    android:textColorHint="@android:color/darker_gray" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Botón de guardar -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGuardar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_ajustes_item"
        android:text="@string/boton_guardar_ajustes_datos_personales"
        android:textAllCaps="false"
        android:textColor="@color/text"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>